{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents public user profiles in Saku Maku",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "photoURL", "email", "createdAt"]
    },
    "Business": {
      "title": "Business",
      "description": "Represents local cafes and shops verified in Iraq",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "object" },
        "description": { "type": "object" },
        "category": { "type": "string" },
        "governorate": { "type": "string" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "image": { "type": "string" },
        "images": { "type": "array" },
        "avatar": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "object" },
        "likes": { "type": "number" },
        "saves": { "type": "number" },
        "ownerUid": { "type": "string" }
      },
      "required": ["id", "name", "category", "governorate", "rating", "reviewsCount", "image"]
    },
    "SocialPost": {
      "title": "SocialPost",
      "description": "A live micro-campaign story published to Saku Maku Feed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "businessName": { "type": "string" },
        "businessAvatar": { "type": "string" },
        "category": { "type": "string" },
        "governorate": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "caption": { "type": "object" },
        "likes": { "type": "number" },
        "commentsCount": { "type": "number" },
        "shares": { "type": "number" },
        "videoUrl": { "type": "string" },
        "authorUid": { "type": "string" }
      },
      "required": ["id", "businessName", "governorate", "mediaUrl", "caption"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Saku Maku user directory lookup."
    },
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "A repository of premium local coffeeshops, salons, high-culture spots."
    },
    "/posts/{postId}": {
      "schema": "SocialPost",
      "description": "Live story cards showing verified campaigns or events."
    }
  }
}
