rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Catch-All Deny Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Security Helpers & Access Layers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Bootstrapped administrator list
    function isAdmin() {
      return isSignedIn() && 
        request.auth.token.email == "safaribosafar@gmail.com";
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Specific Validators ---

    function isValidUserProfile(data) {
      return (!('uid' in data) || (data.uid is string && data.uid.size() <= 128)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1024)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 256)) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 128)) &&
             (!('role' in data) || (data.role is string && (data.role == 'user' || data.role == 'owner' || data.role == 'admin'))) &&
             (!('onboarded' in data) || (data.onboarded is bool)) &&
             (!('businessId' in data) || (data.businessId == null || (data.businessId is string && data.businessId.size() <= 128))) &&
             (!('businessOnboarding' in data) || (data.businessOnboarding is map));
    }

    function isValidBusiness(data) {
      return (!('id' in data) || (data.id is string && data.id.size() <= 128)) &&
             (!('category' in data) || (data.category is string && data.category.size() <= 128)) &&
             (!('governorate' in data) || (data.governorate is string && data.governorate.size() <= 128)) &&
             (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
             (!('reviewsCount' in data) || (data.reviewsCount is number && data.reviewsCount >= 0)) &&
             (!('image' in data) || (data.image is string && data.image.size() <= 2097152)) &&
             (!('avatar' in data) || (data.avatar is string && data.avatar.size() <= 2097152)) &&
             (!('likes' in data) || (data.likes is number)) &&
             (!('ownerUid' in data) || (data.ownerUid is string && data.ownerUid.size() <= 128));
    }

    function isValidSocialPost(data) {
      return (!('id' in data) || (data.id is string && data.id.size() <= 128)) &&
             (!('businessName' in data) || (data.businessName is string && data.businessName.size() <= 256)) &&
             (!('category' in data) || (data.category is string && data.category.size() <= 128)) &&
             (!('governorate' in data) || (data.governorate is string && data.governorate.size() <= 128)) &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 2097152)) &&
             (!('caption' in data) || (data.caption is map)) &&
             (!('likes' in data) || (data.likes is number)) &&
             (!('commentsCount' in data) || (data.commentsCount is number)) &&
             (!('shares' in data) || (data.shares is number)) &&
             (!('authorUid' in data) || (data.authorUid is string && data.authorUid.size() <= 128)) &&
             (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.size() <= 2097152)) &&
             (!('businessId' in data) || (data.businessId is string && data.businessId.size() <= 128)) &&
             (!('businessAvatar' in data) || (data.businessAvatar is string && data.businessAvatar.size() <= 2048));
    }

    function isValidHeroSlide(data) {
      return (!('id' in data) || (data.id is string && data.id.size() <= 128)) &&
             (!('image' in data) || (data.image is string && data.image.size() <= 2097152)) &&
             (!('slogan' in data) || (data.slogan is map)) &&
             (!('governorate' in data) || (data.governorate is string && data.governorate.size() <= 128)) &&
             (!('category' in data) || (data.category is string && data.category.size() <= 128)) &&
             (!('badge' in data) || (data.badge is map));
    }

    // --- Route Endpoints matching definitions ---

    // USERS COLLECTION
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUserProfile(incoming()) && incoming().keys().hasAll(['uid', 'displayName', 'photoURL', 'email', 'createdAt']);
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && 
                    (!('uid' in incoming()) || incoming().uid == existing().uid) && 
                    (!('email' in incoming()) || incoming().email == existing().email);
      allow delete: if isAdmin();
    }

    // BUSINESSES COLLECTION
    match /businesses/{businessId} {
      allow read: if true;
      allow create: if isSignedIn() && (
                    isAdmin() || 
                    (isValidBusiness(incoming()) && 
                     incoming().ownerUid == request.auth.uid &&
                     incoming().isVerified == false)
                  );
      allow update: if isSignedIn() && (
        isAdmin() || 
        (existing().ownerUid == request.auth.uid && 
         isValidBusiness(incoming()) &&
         incoming().ownerUid == existing().ownerUid &&
         incoming().isVerified == existing().isVerified && // block modifying verification status
         incoming().diff(existing()).affectedKeys().hasOnly([
           'name', 'description', 'category', 'governorate', 'phoneNumber', 'address', 'image', 'images', 'avatar', 'mapCoords', 'stories'
         ])
        ) ||
        // Allowing users to increment likes or review counts
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'saves', 'reviewsCount', 'rating']))
      );
      allow delete: if isAdmin() || (isSignedIn() && existing().ownerUid == request.auth.uid);
    }

    // SOCIAL FEEDS/POSTS COLLECTION
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && (
                    isAdmin() ||
                    (isValidSocialPost(incoming()) && 
                     incoming().authorUid == request.auth.uid)
                  );
      allow update: if isSignedIn() && (
        isAdmin() ||
        (existing().authorUid == request.auth.uid && 
         isValidSocialPost(incoming()) &&
         incoming().authorUid == existing().authorUid &&
         incoming().diff(existing()).affectedKeys().hasOnly([
           'caption', 'mediaUrl', 'videoUrl', 'fileAttachment', 'category', 'governorate'
         ])
        ) ||
        // Public interaction like rating, reactions, comments increments
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'commentsCount', 'shares', 'comments']))
      );
      allow delete: if isAdmin() || (isSignedIn() && existing().authorUid == request.auth.uid);
    }

    // HERO SLIDES COLLECTION
    match /hero_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // BUSINESS CLAIMS COLLECTION
    match /business_claims/{claimId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // BUSINESS OWNERS COLLECTION
    match /business_owners/{ownerId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

  }
}
