# Frontend
VITE_API_URL="https://shaku-maku.mahdialmuntadhar1.workers.dev"
# Dev-only. Do not enable fake/local auth fallback in production builds.
VITE_ALLOW_LOCAL_AUTH_FALLBACK="false"

# Optional AI Studio / Gemini usage
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
APP_URL="https://shakumaku.pages.dev"

# Server-side Nabda / WhatsApp integration only
NABDA_API_URL="https://api.nabdaotp.com/your-instance"
NABDA_API_KEY="YOUR_SERVER_ONLY_NABDA_API_KEY"
NABDA_INSTANCE_ID="YOUR_INSTANCE_ID"
NABDA_SEND_PATH="/api/v1/messages/send"
NABDA_AUTH_PREFIX=""
NABDA_MAX_MESSAGE_LENGTH="255"
WHATSAPP_SERVER_PORT="5050"
WHATSAPP_DAILY_LIMIT="200"
WHATSAPP_MAX_BATCH_SIZE="50"
WHATSAPP_DEFAULT_DELAY_SECONDS="5"
NABDA_WEBHOOK_PORT="8787"
NABDA_WEBHOOK_SECRET="CHANGE_ME"
